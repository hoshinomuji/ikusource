# Required: provide one of these DB config styles
DATABASE_URL=postgres://user:password@host:5432/database

# Or use split fields instead of DATABASE_URL
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=appdb
# DB_SSL=false

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session secret (generate a random string)
SESSION_SECRET=your-random-session-secret-here

# Sentry (error monitoring)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Email SMTP settings (optional - can be configured in admin panel)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
SMTP_SENDER_NAME=Ikuzen Studio

# Payment Gateway APIs
TRUEMONEY_API_URL=https://api.mystrix2.me/truemoney
SLIP_VERIFICATION_API_URL=https://slip-c.oiioioiiioooioio.download/api/slip

# Discord Webhook (optional - for notifications)
DISCORD_WEBHOOK_URL=

# Admin email (for initial setup)
ADMIN_EMAIL=admin@yourdomain.com
